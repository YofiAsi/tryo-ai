# Development Dockerfile for tyro-workers with debugpy support
FROM python:3.13-slim

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Install watchdog for file watching and auto-reload
RUN pip install --no-cache-dir watchdog

# Note: Application files will be mounted as volume in docker-compose
# This allows for live file changes without rebuilding the container

# Set environment variables
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONFAULTHANDLER=1

# Expose ports
# 8002: FastAPI application port
# 5679: Debugpy debug port
EXPOSE 8002 5679

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8002/health || exit 1

# Run the server (debugpy is handled internally by server.py)
CMD ["python", "server.py"]
